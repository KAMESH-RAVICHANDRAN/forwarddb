# Appwrite Production Environment Configuration
# Copy this to .env.prod and fill in your values before deployment
# NEVER commit .env.prod to version control

# ========== Docker Hub Registry ==========
DOCKER_HUB_USERNAME=your_dockerhub_username
DOCKER_HUB_PASSWORD=your_dockerhub_password

# ========== Application Settings ==========
APP_DOMAIN=appwrite.example.com
CONSOLE_DOMAIN=console.appwrite.example.com
IMAGE_TAG=latest
APP_VERSION=1.0.0
APP_EDITION=community

# ========== Database Configuration ==========
DB_SCHEMA=appwrite
DB_USER=appwrite
DB_PASS=change_me_to_strong_password
DB_ROOT_PASS=change_me_to_strong_root_password

# ========== Security ==========
OPENSSL_KEY_V1=change_me_to_strong_key_32_chars_min
EXECUTOR_SECRET=change_me_to_strong_secret

# ========== SMTP Configuration ==========
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=change_me_to_smtp_password
SYSTEM_EMAIL_NAME=Appwrite
SYSTEM_EMAIL_ADDRESS=noreply@example.com

# ========== Storage Configuration ==========
STORAGE_DEVICE=local
# For S3:
# STORAGE_DEVICE=s3
S3_ACCESS_KEY=change_me
S3_SECRET=change_me
S3_REGION=us-east-1
S3_BUCKET=appwrite-storage
S3_ENDPOINT=https://s3.amazonaws.com

# ========== Logging ==========
LOGGING_CONFIG=

# ========== SSL/TLS ==========
ACME_EMAIL=admin@example.com

# ========== Version Overrides ==========
CONSOLE_VERSION=latest
EXECUTOR_VERSION=latest
PROXY_VERSION=latest
